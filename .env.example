# 服务端口
PORT=3000

# ========== 支付宝 A2M 商户配置 ==========
# 在支付宝开放平台申请 A2M 商户资质后填入
# https://open.alipay.com

# 应用 ID
ALIPAY_APP_ID=your_app_id_here

# 商户 UID（2088 开头）
ALIPAY_SELLER_ID=your_seller_id_here

# A2M 服务 ID（格式 API_xxxxxxxx）
ALIPAY_SERVICE_ID=your_service_id_here

# 商户 RSA2 私钥（PKCS#1 PEM，多行用 \n 连接）
ALIPAY_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nxxx\n-----END RSA PRIVATE KEY-----

# ========== 业务配置 ==========
# 天气报告单价（元）
WEATHER_PRICE=0.10
